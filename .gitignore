# ==========================================
# Root Gitignore for SceneSolver Repository
# ==========================================

# --- System & IDE files ---
.DS_Store
Thumbs.db
.vscode/
*.suo
*.user

# --- Environment Configuration (Secrets) ---
.env
.env.local
.env.development.local
.env.production.local
.env.test.local
*.env*

# --- Log Files ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python Virtual Environment & Caches ---
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.ipynb_checkpoints/

# --- Model Checkpoints & Weights ---
**/models/*.pt
**/models/*.pth
**/models/*.onnx
**/models/*.bin
yolov8n.pt

# --- Node.js Dependencies ---
**/node_modules/
**/build/
**/dist/

# --- Dynamic Uploads / Local Media Storage ---
# Keep parent directories but ignore user uploads inside them
scenesolver-backend/uploads/*
!scenesolver-backend/uploads/.gitkeep
scenesolver-backend/public/media/*
!scenesolver-backend/public/media/.gitkeep
scenesolver-ai-service/uploads/*
!scenesolver-ai-service/uploads/.gitkeep
